class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
        """
        Do not return anything, modify nums in-place instead.
        """
        zero_counter = 0
        non_zero = []

        for v in nums:
            if v == 0:
                zero_counter += 1
            else:
                non_zero.append(v)

        nums[:] = non_zero

        while zero_counter > 0:
            nums.append(0)
            zero_counter -= 1

